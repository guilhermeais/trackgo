# Environment configuration for TrackGo GPS Simulator
# Copy this file to .env and modify as needed

# Number of carriers to simulate
NUMBER_OF_CARRIERS=5

# Number of trucks per carrier
TRUCKS_PER_CARRIER=10

# Kafka bootstrap servers (comma-separated for multiple brokers)
KAFKA_SERVERS=localhost:9092

# Kafka topic to publish GPS data
KAFKA_TOPIC=raw-gps-data

# MongoDB connection for seeding driver data
MONGO_URI=mongodb://localhost:27017
MONGO_DB=trackgo
MONGO_COLLECTION=truck-drivers

# MongoDB connection for seeding driver data
MONGO_URI=mongodb://localhost:27017
MONGO_DB=trackgo
MONGO_COLLECTION=truck-drivers